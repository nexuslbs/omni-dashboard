# Ignore everything at root level
/*
!.gitignore
!README.md
!AGENTS.md
!/*/

# Ignore all files/dirs inside project directories by default
/*/*
# Then un-ignore specific ones we want to track
!/*/docker-compose.yml
!/*/base.env
!/*/build/
!/*/build/**

# Ignore repo/ contents (the cloned repos)
/*/repo/**

# Ignore .env credential files (copied from base.env)
/*/.env

# Ignore projects starting with omni* (avoid container/network name collisions)
/omni*

# Ignore macOS artifacts
.DS_Store
